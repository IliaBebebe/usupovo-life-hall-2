# Vercel Postgres (Neon) Connection String
# Получите в панели управления Vercel (Storage → Postgres) или Neon
# Формат: postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Основное подключение (через pgbouncer - рекомендуется)
POSTGRES_URL=postgresql://user:password@host.region.aws.neon.tech/dbname?channel_binding=require&sslmode=require

# Подключение без pgbouncer (для специальных случаев)
POSTGRES_URL_NON_POOLING=postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require

# Отдельные параметры (опционально)
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_HOST=
# POSTGRES_DATABASE=
