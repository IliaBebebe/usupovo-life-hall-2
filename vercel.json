{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "devCommand": "npm run dev",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/favicon.ico",
      "destination": "/public/images/logo-small.png"
    }
  ],
  "regions": ["fra1"]
}
